{
  "name": "fipi-parser",
  "version": "1.0.0",
  "description": "FIPI open task bank parser — extracts questions from fipi.ru into JSON compatible with Phase 18 import contract",
  "type": "module",
  "scripts": {
    "parse": "bun run src/index.ts",
    "parse:dry": "bun run src/index.ts --dry-run",
    "parse:subject": "bun run src/index.ts --subject",
    "install-browser": "npx playwright install chromium"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
